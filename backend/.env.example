# ── Core secrets (REQUIRED) ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-hex-secret
JWT_SECRET=change-me-generate-another-random-hex-secret

# ── Database ───────────────────────────────────────────────────────────────
# For docker compose: postgresql://hospital:hospital@db:5432/hospital
# For local dev:      postgresql://localhost/hospital_dev
DATABASE_URL=postgresql://hospital:hospital@localhost:5432/hospital

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI providers (at least one required for AI features) ──────────────────
# Gemini free tier is recommended — get a key at https://aistudio.google.com
GEMINI_API_KEY=

# OpenAI fallback (paid account required)
OPENAI_API_KEY=

# Override the chat model (optional — defaults to gemini-2.5-flash or gpt-4o-mini)
# CHATBOT_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=gemini-embedding-001

# ── Google OAuth (optional — leave blank to disable) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Mock Stripe webhook (optional override — defaults to a dev-only value)
# Sent by the frontend as the X-Webhook-Secret header on calls to
# POST /billing/stripe/webhook. This stands in for real Stripe signature
# verification (stripe.Webhook.construct_event) until a live key is wired
# up — see app/routes/stripe_mock.py for the migration note. Generate with:
# python -c "import secrets; print('whsec_' + secrets.token_hex(24))"
STRIPE_WEBHOOK_SECRET=whsec_mock_dev_only_change_me

# ── Frontend URL (used for CORS) ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate limiting (optional overrides — defaults shown) ───────────────────
# RATE_CHATBOT=20/minute
# RATE_AI_SUMMARY=10/minute
# RATE_AI_NOTES=10/minute
# RATE_AI_CLINICAL=10/minute
# RATE_OCR=15/minute

# ── FAISS index path (optional — default: medical_guidelines_index/) ───────
# FAISS_INDEX_PATH=medical_guidelines_index

# ── Enforce secrets at startup (set to production to raise on missing secrets)
# ENV=production
